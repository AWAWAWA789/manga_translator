<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#6200EE"
        android:padding="20dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:layout_marginEnd="15dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设置"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 默认翻译器选择 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="默认翻译器"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="15dp" />

                <RadioGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="15dp">

                    <RadioButton
                        android:id="@+id/radio_mimo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="MiMo AI（推荐，质量更高）"
                        android:textSize="16sp"
                        android:padding="10dp" />

                    <RadioButton
                        android:id="@+id/radio_baidu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="百度翻译（速度更快）"
                        android:textSize="16sp"
                        android:padding="10dp" />
                </RadioGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="百度状态: "
                        android:textSize="14sp"
                        android:textColor="#666666" />

                    <TextView
                        android:id="@+id/tv_baidu_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未配置"
                        android:textSize="14sp"
                        android:textColor="#FF0000" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  |  MiMo状态: "
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:layout_marginStart="20dp" />

                    <TextView
                        android:id="@+id/tv_mimo_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未配置"
                        android:textSize="14sp"
                        android:textColor="#FF0000" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_default_translator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="保存默认翻译器"
                    android:textSize="14sp"
                    android:backgroundTint="#6200EE"
                    android:layout_marginTop="15dp" />
            </LinearLayout>

            <!-- 百度翻译API配置 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="百度翻译API配置"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="15dp" />

                <!-- 说明 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#F0F8FF"
                    android:padding="12dp"
                    android:layout_marginBottom="15dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="如何获取百度翻译API："
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1. 访问 fanyi-api.baidu.com\n2. 注册并登录\n3. 开通通用翻译API\n4. 获取APP ID和密钥"
                        android:textSize="13sp"
                        android:textColor="#666666"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

                <!-- APP ID -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APP ID"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="5dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_baidu_app_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="请输入百度翻译APP ID"
                        android:inputType="text"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 密钥 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="密钥"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="5dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_baidu_secret_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="请输入百度翻译密钥"
                        android:inputType="textPassword"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_test_baidu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="测试百度"
                        android:textSize="14sp"
                        android:backgroundTint="#03DAC6"
                        android:textColor="#000000"
                        android:layout_marginEnd="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_baidu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="保存百度配置"
                        android:textSize="14sp"
                        android:backgroundTint="#6200EE" />
                </LinearLayout>
            </LinearLayout>

            <!-- MiMo AI API配置 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MiMo AI API配置"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="15dp" />

                <!-- 说明 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFF8E1"
                    android:padding="12dp"
                    android:layout_marginBottom="15dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MiMo AI说明："
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1. AI翻译质量更高，更适合漫画\n2. 能理解上下文和角色语气\n3. 速度可能较慢\n4. 需要有效的API Key"
                        android:textSize="13sp"
                        android:textColor="#666666"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

                <!-- API Key -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="API Key"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="5dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_mimo_api_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="请输入MiMo API Key"
                        android:inputType="textPassword"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Base URL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Base URL（可选）"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="5dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_mimo_base_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="默认: https://api.xiaomimimo.com/v1/chat/completions"
                        android:inputType="textUri"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Model -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Model（可选）"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="5dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_mimo_model"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="默认: mimo-v2.5"
                        android:inputType="text"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_test_mimo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="测试MiMo"
                        android:textSize="14sp"
                        android:backgroundTint="#FF9800"
                        android:textColor="#000000"
                        android:layout_marginEnd="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_mimo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="保存MiMo配置"
                        android:textSize="14sp"
                        android:backgroundTint="#6200EE" />
                </LinearLayout>
            </LinearLayout>

            <!-- AI多模态识别设置 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI多模态识别"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="15dp" />

                <!-- 说明 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#E8F5E9"
                    android:padding="12dp"
                    android:layout_marginBottom="15dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI多模态识别说明："
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="使用MiMo Vision API一次性完成：\n1. 气泡检测 - 识别各种形状的对话气泡\n2. 文字识别 - 识别气泡内的日文原文\n3. 翻译 - 将日文翻译成自然中文\n4. 输出定位 - 精确覆盖在原文位置\n\n需要配置MiMo API Key。\n仅在手动翻译时启用，实时翻译仍走本地流程。"
                        android:textSize="13sp"
                        android:textColor="#666666"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_ai_bubble_detection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="启用AI多模态识别"
                    android:textSize="16sp"
                    android:padding="10dp"
                    android:checked="false" />

                <TextView
                    android:id="@+id/tv_ai_bubble_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="状态：已关闭"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginTop="10dp" />
            </LinearLayout>

            <!-- 说明 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="关于翻译功能"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="- OCR识别：本地Google ML Kit 或 AI多模态\n- 文本翻译：百度或MiMo AI\n- 气泡检测：OpenCV本地 或 AI多模态\n- 翻译结果：原位覆盖显示\n- 只需配置一个翻译器即可使用"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>